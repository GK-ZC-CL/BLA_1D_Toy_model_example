# Setting up input we need:
xP <- seq(0,3,length = 100) # total inputs we have
xD <- seq(0,3,length = 6)   # some running inputs we want to test
f_x <- toy_model(xP)        # true model's output
D <- toy_model(xD)          # model's output for some running inputs
sigma <- 1                  # emulator's prior belief for sigma
theta <- 1                  # emulator's prior belief for theta
E_f <- 0                    # prior of the expectation of the simulator f(x), E[f(x)]
Var_f <- sigma              # prior of the variance of simulator f(x), Var[f(x)]
sigma_e <- 0.005            # observation error
sigma_epsilon <- 0          # model's discrepancy
z <- 0.75                   # observation/target signal

# Wave 1 BLA emulation result (including E_D[f(x)], Var_D[f(x)]):
emout <- Emulator_1D(xP = xP,xD = xD, D = D, E_f = 0, sigma = 1, theta = 1)

# Plot Wave 1 BLA E_D[f(x)] and f(x) with interval:
plot_BL_emulator(em_out = emout, xP = xP, xD = xD, D = D, 
                 #maintitle = "Emulator's Prediction vs Model's Real Function", 
                 z = z, sigma_e = 0.005, sigma_epsilon = 0, plot_true = T) 

# Plot Wave 1 BLA Var_D[f(x)], but posterior variance only instead of the whole covariance matrix:
plot(x = xP, y = emout[[3]], type = 'l', xlab='x', ylab = 'Variance for each x',lwd=2,col='violetred1',ylim=c(0,0.005))
points(x = xD, y=rep(0,length(xD)), col='black', pch=21, bg='green')

# Wave 1 History matching (Implausibility Measure):
# $I^2(x) = \frac{(\text{E}_D[f(x)] - z)^2}{\text{Var}_D[f(x)]+\text{Var}[e]+\text{Var}[\epsilon]}, \text{where} \space \text{Var}[e] = \sigma_e^2, \text{Var}[\epsilon]=\sigma_\epsilon^2$

Implaus <- sqrt((emout[[1]] - z)^2/(emout[[3]]+sigma_e^2+sigma_epsilon^2))

# Corresponding Visualisation of Wave 1 E_D[f(x)] and the corresponding implausibility measure:
plot_BL_emulator_V2_implau(em_out = emout, xP = xP, xD = xD, D = D, 
                           maintitle = 
                             'Emulator Prediction with Implausibility Measure at z = 0.75', z = 0.75, sigma_e = sigma_e, sigma_epsilon = 0, 
                           plot_true = TRUE, Implaus = Implaus,
                           colscheme = turbo)


# Preparing for Wave 2 emulation based on the result of Wave 1 History Matching above:

# Create a list for the whole input xP with the corresponding Implausibility measurement:
xP_implausibility_list <- list('Input' = xP, 'Implausibility' = Implaus)

# Find non-implausible running inputs based on previous Implausibility measurement:
xD_non_implau <- xP[which(xP_implausibility_list$Implausibility <= 3)]

# Create new running inputs xD for Wave 2 emulation:
xD_wave2 <- c(xD,xD_non_implau) 

# Wave 2 BLA Emulation:
xD_wave2 <- c(xD,xD_non_implau) 
D_wave2 <- toy_model2(xD_wave2)
emout_wave2 <- Emulator_1D(xP = xP, xD = xD_wave2, D = D_wave2)
adj_var_bla <- emout_wave2[[2]] # Var_D[f(x)]

# Plot the Wave 2 emulator result:
plot_BL_emulator(em_out = emout_wave2, xP = xP, xD = xD_wave2, D = D_wave2, 
                 maintitle =
                      "Emulator's Prediction vs Model's Real Function Wave 2", 
                 z = z, sigma_e = 0.005, sigma_epsilon = 0, 
                 plot_true = T) 

# Implausibility Measure for wave 2:
z <- 0.75
Implaus_wave2 <- sqrt((emout_wave2[[1]] - z)^2/
                        (emout_wave2[[3]]+sigma_e^2+sigma_epsilon^2))

# Plot new Implausibility Measure for wave 2:
plot_1D_Implausibility(Implaus = Implaus_wave2, imp_cutoff = 3, xP = xP, 
                       colscheme = turbo,
                       maintitle = 'Implausibility Plot for each input by Wave 2')

# Plot the Wave 2 BLA emulation result with corresponding Implausibility Measure
plot_BL_emulator_V2_implau(em_out = emout_wave2, xP = xP, xD = xD_wave2, 
                           D = D_wave2, 
                           maintitle = 
                             'Wave 2 BLA Emulator Prediction with Implausibility at z = 0.75', z = 0.75, sigma_e = 0.005, sigma_epsilon = 0, 
                           plot_true = TRUE, Implaus = Implaus_wave2, 
                           colscheme = turbo)

# Plot Wave 2 BLA Var_D[f(x)], but posterior variance only instead of the whole covariance matrix:
plot(x = xP, y = emout_wave2[[3]], type = 'l', xlab='x', ylab = 'Variance for each x',lwd=2,col='violetred1',ylim=c(0,0.005))
points(x = xD_wave2, y=rep(0,length(xD_wave2)), col='black', pch=21, bg='green')
