# Toy model f(x) = sin (2*pi*x)
toy_model <- function(x) sin(2*pi*x)

# BLA Emulator's Construction:
Emulator_1D <- function(xP,       # total inputs we have
                        xD,       # some running inputs we want to test
                        D,        # model's output for running inputs xD
                        E_f = 0,  # prior of the expectation of the simulator f(x), E[f(x)]
                        sigma = 1,# emulator's prior belief for scale parameter sigma
                        theta = 1 # emulator's prior belief for lengthscale parameter theta
){
  library(plgp)
  n <- length(D)
  m <- length(xP)
  eps <- sqrt(.Machine$double.eps)

  # Construct a function to compute the Gaussian kernel-based covariance matrix:
  Cov_fx_fxprime <- function(x, xprime){
    sigma^2 * exp(-distance(x, xprime)/(theta^2))
  }

  # Covariance matrix Var[D] for our running input:
  Var_D <- Cov_fx_fxprime(xD,xD) + diag(eps, nrow = n, ncol = n)

  # Prior expectation for output from running xD, i.e. E[D]
  E_D <- rep(E_f, n) 

  # Cov[f(x), D]
  Cov_fx_D <- Cov_fx_fxprime(xP, xD)

  # Var[f(x)]
  Var_fx <- sigma

  # Posterior Adjusted expectation wrt D, i.e. E_D[f(x)]:
  Emulator_Expectation <- E_f + Cov_fx_D %*% chol2inv(chol(Var_D)) %*% (D - E_D)
  
  # Posterior Adjusted variance wrt D, i.e. Var_D[f(x)]
  Emulator_Variance <- Var_fx - Cov_fx_D %*% chol2inv(chol(Var_D)) %*% t(Cov_fx_D)
  diag_Emulator_Variance <- diag(Emulator_Variance)
  
  return(list('E_D[f(x)]' = Emulator_Expectation, 
              'Var_D[f(x)]' = Emulator_Variance, 
              'Diag(Var_D[f(x)])' = diag_Emulator_Variance))
}


# Plotting Emulator result function:
plot_BL_emulator <- function(
    em_out,
    xP,
    xD,
    D,
    maintitle = NULL,
    z = NULL,             #the observation data
    sigma_e = NULL,       #the observation error
    sigma_epsilon = NULL, #the model's discrepancy
    plot_true = FALSE,    #Never plot the true functions unless it is TRUE
    ...){
  
  plot(xP, em_out[[1]], ylim = c(-1.3, 1.2), 
       type = 'l', col = 'blue', 
       xlab="Input parameter x",ylab="Output f(x)",main=maintitle)
  
  if (plot_true == TRUE){
    lines(xP, toy_model2(xP), lwd = 2, lty = 1) 
  }
  
  lines(xP, em_out[[1]] + 3 * sqrt(em_out[[3]]), 
        col = 'red', lwd = 2.5) 
  lines(xP, em_out[[1]] - 3 * sqrt(em_out[[3]]), col = 'red', lwd = 2.5)
  
  
  #plot the runs (the tested points we ran already):
  points(xD, D, pch = 21, col = 1, bg = 'green', cex = 1.5)
  
  # Plot the observed data plus errors due to observations and Model's Discrepancy
  if (is.null(z) == FALSE){
    abline(h = z, lwd = 1.4)
    abline(h = z + 3*sqrt(sigma_e + sigma_epsilon), lty = 2, lwd = 1.2)
    abline(h = z - 3*sqrt(sigma_e + sigma_epsilon), lty = 2, lwd = 1.2)
  }
  
  if (plot_true == F){
    legend('topright', legend = c("Emulator Expectation", 
                                  "Emulator Prediction Interval", 
                                  "True Function f(x)", 
                                  "Model Evaluated Points"),
           lty = c(1,1,1,NA), pch = c(NA, NA, NA, 16), 
           col=c("blue","red","yellow","green"),lwd=2.5,pt.cex=0.6, cex = 0.4)
  }
  
  if (!is.null(z)){
    legend('topright', legend = c("Emulator Expectation", 
                                  "Emulator Prediction Interval", 
                                  "Model Evaluated Points", 
                                  "Observation z at 0.75",
                                  "Observation Error (3-sigma) Interval"),
           lty = c(1,1,NA,1,2), pch = c(NA, NA, 16, NA, NA), 
           col=c("blue","red","green","black", "black"),
           lwd=c(2.5,2.5,NA,1.4,1.2), pt.cex=0.6, cex = 0.4)
  }
}

# Plotting History Matching result function:
plot_1D_Implausibility <- function(
    Implaus,          # Implausibility Measurement
    imp_cutoff = 3,   # "non-implausible" cutoff point
    xP,               # All input
    maintitle = NULL,
    colscheme = NULL){
  
  imp_breaks <- c(seq(0,2.8,0.2),
                  seq(3,9.5,0.5),
                  10, Inf)   # colour steps for the implausibility measurement result
  
  imp_cut_index <- cut(Implaus, imp_breaks, labels = F)
  
  if (!is.null(colscheme)) {
    cols <- colscheme(n = length(imp_breaks)-1, begin = 0, end = 1)
  } # assign reduced "turbo" colours
  
  else{
    cols <- rainbow(38)
  }

  # plot the line of the implausibility measure I(x) based on x:
  plot(xP, Implaus, ylim = c(0,30), ty = 'l', lwd = 2, 
       xlab = 'Input Parameter x', ylab = 'Implausibility Measure',
       main = maintitle) 
  
  # Horizontal line of the non-implausible level:  
  abline(h = imp_cutoff, col = 'green', lwd = 2) 
  
  rect_wid <- 1/(length(xP)-1) # set up simple rectangles to colour x-axis
  
  points(x = xP, rep(0, length(xP)), col = cols[imp_cut_index], pch=15, cex=1)
  
  #abline(h = 0, col = 1, lwd = 1)
  
  legend('topright', legend = c('Implausibility Measure I(x)', 
                                'Non-Implausible cutoff line = 3.0'),
         lty = c(1,1), col = c('black', 'green'), lwd = 2, cex = 0.5)
  
}

